{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InkFlow",
  "version": "1.0.1",
  "identifier": "com.inkflow.studio",
  "build": {
    "beforeDevCommand": "node scripts/dev-frontend.mjs",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "node scripts/build-frontend.mjs",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "InkFlow",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 15 },
        "shadow": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/inkflow-server"],
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "12.0"
    }
  }
}

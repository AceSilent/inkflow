# AutoNovel-Studio Configuration
# Copy this file to .env and fill in your values

# LLM Provider Configuration
# Supported providers: openai, deepseek, kimi, etc.
LLM_PROVIDER=openai

# Codex / ChatGPT OAuth provider (kind = "codex-oauth")
# ---------------------------------------------------------------------------
# A Codex provider authenticates with your ChatGPT subscription via OAuth — it
# does NOT use an API key. Do not set any key here for it. Instead, add a
# provider with kind "codex-oauth" in the in-app Settings panel and click "登录
# ChatGPT"; the app opens the OpenAI login in your browser, captures the
# callback on http://localhost:1455/auth/callback (falls back to 1457), and
# stores the rotating credentials in <AUTONOVEL_DATA_DIR>/.codex_auth.json
# (file mode 0600). Tokens refresh automatically; no manual configuration here.

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
KIMI_API_KEY=your_kimi_api_key_here

# API Base URLs (optional, for compatible endpoints)
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Model Configuration
AUTHOR_MODEL=gpt-4o-mini
EDITOR_MODEL=gpt-4o
READER_MODEL=gpt-4o-mini

# Temperature Settings
AUTHOR_TEMPERATURE=0.8
EDITOR_TEMPERATURE=0.2
READER_TEMPERATURE=0.3

# Retry Settings
MAX_RETRIES=3
TIMEOUT=120

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/autonovel.log

# State Machine
CIRCUIT_BREAKER_MAX_RETRIES=3

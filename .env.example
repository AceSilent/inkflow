# InkFlow — Game Script Authoring Studio Configuration
# Copy this file to .env and fill in your values

# LLM Provider Configuration
# Supported providers: openai, deepseek, kimi, etc.
LLM_PROVIDER=openai

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
KIMI_API_KEY=your_kimi_api_key_here

# API Base URLs (optional, for compatible endpoints)
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Model Configuration
AUTHOR_MODEL=gpt-4o-mini
EDITOR_MODEL=gpt-4o
READER_MODEL=gpt-4o-mini

# Temperature Settings
AUTHOR_TEMPERATURE=0.8
EDITOR_TEMPERATURE=0.2
READER_TEMPERATURE=0.3

# Retry Settings
MAX_RETRIES=3
TIMEOUT=120

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/autonovel.log

# State Machine
CIRCUIT_BREAKER_MAX_RETRIES=3

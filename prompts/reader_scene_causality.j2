```json
{
  "reader_role": "scene_causality_checker",
  "pass_status": false,
  "issues": [
    {
      "type": "Dropped_Foreshadow",
      "severity": 5,
      "quote": "（整个 stage 未提及'玄铁令'）",
      "missing_link": "前一个 stage 结尾明确留下'玄铁令必须在三日内上交'的悬念，本 stage 时间已过三日却未交代后果",
      "fix_instruction": "在本 stage 前段补一段主角发现玄铁令被偷/或被迫违约的交代，承接前 stage 钩子"
    },
    {
      "type": "Weak_Motive",
      "severity": 3,
      "quote": "林辰决定背叛师门",
      "missing_link": "背叛这种级别的选择没有情绪铺垫、没有对师门的最后一次挣扎",
      "fix_instruction": "至少加一段内心独白或一个触发事件（如师父刚否定他），让选择有成本感"
    }
  ],
  "quick_comment": "重要伏笔失收 + 关键选择缺动机铺垫"
}
```

